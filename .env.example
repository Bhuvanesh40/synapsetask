# Database & ORM Connections (Neon Serverless Postgres)
# Replace with your actual database connection strings
DATABASE_URL="postgresql://user:password@ep-host.region.pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-host.region.neon.tech/neondb?sslmode=require"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secure secret
AUTH_SECRET="your-next-auth-secret-here-at-least-32-chars"
NEXTAUTH_SECRET="your-next-auth-secret-here-at-least-32-chars"
# Set to your hosting domain (e.g. http://localhost:3000 in development)
NEXTAUTH_URL="http://localhost:3000"

# Token Encryption Secret
# AES-256 key derivation secret. Keep this private and consistent to prevent data loss.
ENCRYPTION_KEY="your-encryption-key-for-jira-github-tokens-32-chars"

# Google Gemini API Studio
# Obtain from https://aistudio.google.com
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"
